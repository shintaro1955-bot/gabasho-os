# ガバショ！OS サーバー設定（このファイルを .env にコピーして使う）

# Anthropic APIキー（サーバー側のみ。ブラウザには出ません）。未設定だとAIはモック動作。
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 使うモデル（省略時 claude-opus-4-8）。高頻度・コスト重視なら claude-haiku-4-5 等に。
GABASHO_MODEL=claude-opus-4-8

# セッションCookieの署名鍵（本番では必ずランダムな長い文字列に）
SESSION_SECRET=please-change-to-a-long-random-string

# 初回起動で発行する各アカウントの共通パスワード（省略時 gabasho123）
DEMO_PASSWORD=gabasho123

# ポート（省略時 4200）
PORT=4200
